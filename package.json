{
  "name": "blockchain-application-firewall",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy-lua",
    "copy-lua": "copyfiles -u 1 src/rateLimiter/token_bucket.lua dist",
    "start": "node dist/index.js",
    "lint": "echo \"No linter configured\"",
    "load:example": "ts-node scripts/gen-load.ts"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.7.0",
    "p-queue": "^8.1.0",
    "p-retry": "^7.0.0",
    "prom-client": "^14.2.0",
    "uuid": "^11.1.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@types/chai": "^5.2.2",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.12",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "chai": "^4.3.7",
    "copyfiles": "^2.4.1",
    "ethers": "^5.8.0",
    "hardhat": "^2.17.0",
    "mocha": "^11.7.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "description": "Backend del TFG: un cortafuegos de aplicación para bloquear/permitir llamadas JSON-RPC a un nodo Ethereum según reglas estáticas y heurísticas.",
